RewriteEngine On
# Redirection canonique : force https + www en une seule etape (evite la chaine 301)
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.tempo-assurance.com%{REQUEST_URI} [R=301,L]
# === Redirection de l'ancien blog vers les pages statiques pertinentes (301) ===
# Chaque ancien article pointe vers la page la plus pertinente ; la FAQ sert de filet
# de securite pour tout le reste. Le "?" final supprime la query string d'origine.
# Les regles specifiques (avec leurs conditions sur la query string) passent AVANT le fallback.

# Carte grise barree / pas a mon nom -> page dediee
RewriteCond %{QUERY_STRING} carte-grise-est-barree [NC,OR]
RewriteCond %{QUERY_STRING} carte-grise-n-est-pas-a-mon-nom [NC]
RewriteRule ^blog(/index\.php)?/?$ /carte-grise-barree.html? [R=301,L]

# Vehicule immobilise / fourriere -> page sortie de fourriere
RewriteCond %{QUERY_STRING} fourriere [NC,OR]
RewriteCond %{QUERY_STRING} vehicule-immobilise [NC]
RewriteRule ^blog(/index\.php)?/?$ /assurance-temporaire-sortie-fourriere.html? [R=301,L]

# Permis etranger / pays couverts -> page assurance frontiere
RewriteCond %{QUERY_STRING} permis-etranger [NC,OR]
RewriteCond %{QUERY_STRING} pays-couverts [NC]
RewriteRule ^blog(/index\.php)?/?$ /assurance-temporaire-frontiere.html? [R=301,L]

# Pourquoi / pour qui une assurance auto temporaire -> page auto
RewriteCond %{QUERY_STRING} pour-qui [NC,OR]
RewriteCond %{QUERY_STRING} pourquoi-une-assurance-auto [NC]
RewriteRule ^blog(/index\.php)?/?$ /assurance-temporaire-auto.html? [R=301,L]

# Comment / ou souscrire en ligne -> page devis et souscription
RewriteCond %{QUERY_STRING} comment-souscrire [NC,OR]
RewriteCond %{QUERY_STRING} souscrire-immediatement [NC,OR]
RewriteCond %{QUERY_STRING} quel-site-pour-souscrire [NC]
RewriteRule ^blog(/index\.php)?/?$ /devis-ou-souscription.html? [R=301,L]

# Combien de temps pour etre assure -> page 1 jour (attestation immediate)
RewriteCond %{QUERY_STRING} combien-de-temps-faut-il-pour-etre-assure [NC]
RewriteRule ^blog(/index\.php)?/?$ /assurance-temporaire-1-jour.html? [R=301,L]

# Filet de securite : tout le reste du blog (RC, accident, attestation, annulation,
# resiliation, pages category/author/id...) -> FAQ
RewriteRule ^blog(/.*)?$ /faq-assurance-temporaire.html? [R=301,L]
# Page Espace professionnel supprimee -> redirection vers Contact
RewriteRule ^espace-professionel\.html$ /contact.html [R=301,L]
# Page Poids lourd consolidee -> Camion (+3,5 t)
RewriteRule ^assurance-temporaire-poids-lourd\.html$ /assurance-temporaire-camion.html [R=301,L]
# Anciennes pages news fusionnees dans la page Actualites
RewriteRule ^news---blocage-des-tarifs\.html$ /actualites.html [R=301,L]
RewriteRule ^news---extension-dom\.html$ /actualites.html [R=301,L]
RewriteRule ^news---jl-assure-la-solution\.html$ /actualites.html [R=301,L]
RewriteRule ^news---mise-en-fourriere\.html$ /actualites.html [R=301,L]
# Direction vers page erreur 404
ErrorDocument 404 /404.html

#Protection XSS, clickJacking et Mime-Type
<ifModule mod_headers.c>
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
Header always append X-Frame-Options SAMEORIGIN
Header set X-XSS-Protection "1; mode=block"
Header set X-Content-Type-Options nosniff
# CSP : sans 'unsafe-eval' (le moteur WebSite X5 qui en avait besoin a ete retire)
Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://*.google-analytics.com https://*.clarity.ms; connect-src 'self' https://*.google-analytics.com https://analytics.google.com https://*.analytics.google.com https://www.googletagmanager.com https://*.clarity.ms https://c.bing.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; frame-src https://www.jlassure.com https://certimat.fr https://www.google.com https://maps.google.com; object-src 'none'; base-uri 'self'"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header set Permissions-Policy "accelerometer=(), payment=(self), geolocation=(self), fullscreen=(), autoplay=(), camera=(), display-capture=(self), tools=(self \"https://www.jlassure.com\")"
</ifModule>

# protection contre les injections de fichiers
RewriteCond %{REQUEST_METHOD} GET
RewriteCond %{QUERY_STRING} [a-zA-Z0-9_]=http:// [OR]
RewriteCond %{QUERY_STRING} [a-zA-Z0-9_]=(\.\.//?)+ [OR]
RewriteCond %{QUERY_STRING} [a-zA-Z0-9_]=/([a-z0-9_.]//?)+ [NC]
RewriteRule .* - [F]

# php -- BEGIN cPanel-generated handler, do not edit
# Définissez le package « ea-php72 » comme langage de programmation « PHP » par défaut.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php72 .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

RedirectMatch 404 /\.git
# Blocage des fichiers de documentation interne (.md)
RedirectMatch 404 (?i)\.md$

# ===== PERFORMANCE =====
# Compression gzip des ressources texte
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml \
    application/javascript application/x-javascript application/json \
    application/xml application/rss+xml image/svg+xml
</IfModule>

# Cache navigateur des ressources statiques
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/x-javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
